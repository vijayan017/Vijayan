#include <stdio.h>
#include <math.h>

int main() {
    int num, first, last, digits = 0, temp, swapped;

    printf("Enter a number: ");
    scanf("%d", &num);

    last = num % 10;
    temp = num;

    while(temp > 0) {
        digits++;
        temp /= 10;
    }

    first = num / pow(10, digits - 1);

    // Remove first and last digits
    int middle = (num % (int)pow(10, digits - 1)) / 10;

    // Form new number
    swapped = last * pow(10, digits - 1) + middle * 10 + first;

    printf("Swapped number = %d", swapped);

    return 0;
}

