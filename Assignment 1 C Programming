#include <stdio.h>

int main() {
    int num, a, b, c;

    printf("Enter a 3-digit number: ");
    scanf("%d", &num);

    a = num / 100;
    b = (num / 10) % 10;
    c = num % 10;

    printf("Permutations:\n");
    printf("%d%d%d\n", a,b,c);
    printf("%d%d%d\n", a,c,b);
    printf("%d%d%d\n", b,a,c);
    printf("%d%d%d\n", b,c,a);
    printf("%d%d%d\n", c,a,b);
    printf("%d%d%d\n", c,b,a);

    return 0;
}

