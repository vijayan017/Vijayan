
#include <stdio.h>
#include <math.h>

int main() {
    int x, n, choice;

    printf("Enter two numbers: ");
    scanf("%d %d", &x, &n);

    printf("\n1.Add\n2.Sub\n3.Mul\n4.Div\n5.Power\n");
    printf("Enter your choice: ");
    scanf("%d", &choice);

    if(choice == 1)
        printf("Result = %d", x + n);
    else if(choice == 2)
        printf("Result = %d", x - n);
    else if(choice == 3)
        printf("Result = %d", x * n);
    else if(choice == 4)
        printf("Result = %.2f", (float)x / n);
    else if(choice == 5)
        printf("Result = %.2lf", pow(x, n));
    else
        printf("Invalid choice");

    return 0;
}

