int main() {
    int M, N, evenCount = 0;

    printf("Enter M and N: ");
    scanf("%d %d", &M, &N);

    printf("All Odd Numbers = ");
    for(int i = M; i <= N; i++) {
        if(i % 2 != 0)
            printf("%d ", i);
        else
            evenCount++;
    }

    printf("\nAll Even Numbers count = %d", evenCount);

    return 0;
}

