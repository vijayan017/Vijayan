int main() {
    int a[10] = {1,2,3,4,5}, i, pos=2, value=99, n=5;

    for(i=n; i>pos; i--) {
        a[i] = a[i-1];
    }

    a[pos] = value;
    n++;

    for(i=0;i<n;i++)
        printf("%d ", a[i]);

    return 0;
}
