int main() {
    int a[]={5,2,8,1,3}, i, min=a[0], sec=999;

    for(i=0;i<5;i++)
        if(a[i]<min) min=a[i];

    for(i=0;i<5;i++)
        if(a[i]>min && a[i]<sec) sec=a[i];

    printf("Second min=%d",sec);
}
