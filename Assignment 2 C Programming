#include <stdio.h>
int main() {
    int a[2][2]={{1,2},{5,3}};
    int b[2][2]={{2,3},{4,11}};
    int c[2][2]={0},i,j,k;

    for(i=0;i<2;i++)
        for(j=0;j<2;j++)
            for(k=0;k<2;k++)
                c[i][j]+=a[i][k]*b[k][j];

    for(i=0;i<2;i++) {
        for(j=0;j<2;j++)
            printf("%d ",c[i][j]);
        printf("\n");
    }
}
