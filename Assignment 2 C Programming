#include <stdio.h>
int main() {
    int a[]={14,14,15,25,31,31,32}, i,j,n=7;

    for(i=0;i<n;i++) {
        for(j=i+1;j<n;j++) {
            if(a[i]==a[j]) {
                for(int k=j;k<n-1;k++)
                    a[k]=a[k+1];
                n--; j--;
            }
        }
    }

    for(i=0;i<n;i++) printf("%d ",a[i]);
}
